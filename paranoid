#!/usr/bin/env bash
# paranoid — интерактивный лаунчер экосистемы Paranoid Tools (Фаза A).
#
# ЧЕСТНО: это ТОНКИЙ лаунчер, не новый инструмент. Он не содержит крипты и НЕ трогает
# секреты — секреты вводятся напрямую в stdin нужного CLI. paranoid лишь показывает живой
# статус и запускает те же пять подписанных CLI, ничего не пряча (Scope & limitations и
# вердикты `check` идут на экран как есть). Глобального хоткея/демона тут нет — это Фаза B.
#
# Зависимостей — ноль (чистый Bash). Установленные тулы ищутся в PATH по имени; отсутствующий
# тул показывается серым с хинтом на установку, а не подделывается.
set -uo pipefail

PARANOID_VERSION="0.1.0"

# Точка монтирования vault (та же, что у securetrash). Переопределяема (тесты/иной том).
VAULT_VOLUME="${ST_VAULT_VOLUME:-/Volumes/SecretVault}"
# Файл-контейнер vault (securetrash default). Нужен, чтобы отличить «закрыт» от «ещё не создан»
# — иначе пункт меню Vault на чистой системе вёл бы к тупику «нет контейнера».
VAULT_CONTAINER="${ST_VAULT_PATH:-$HOME/SecureVault.sparsebundle}"

# --- locale: en по умолчанию; ru — если ST_LANG или системная локаль начинаются с 'ru' ---
_detect_locale() {
  local want="${ST_LANG:-}"
  if [[ -n "$want" ]]; then
    case "$want" in ru*) echo ru ;; *) echo en ;; esac
    return
  fi
  case "${LC_ALL:-${LANG:-}}" in ru*) echo ru ;; *) echo en ;; esac
}
LOCALE="${ST_LOCALE:-$(_detect_locale)}"

# --- цвет только в TTY ---
if [[ -t 1 ]]; then
  C_GRN=$'\033[32m'; C_YEL=$'\033[33m'; C_DIM=$'\033[2m'; C_BLD=$'\033[1m'; C_RST=$'\033[0m'
else
  C_GRN=""; C_YEL=""; C_DIM=""; C_BLD=""; C_RST=""
fi

