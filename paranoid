# --- инструменты экосистемы: имя|репо (для хинта на установку) ---
_tool_repo() {
  case "$1" in
    securetrash) echo 'https://github.com/Di-kairos/securetrash' ;;
    vaultwatch)  echo 'https://github.com/Di-kairos/vaultwatch' ;;
    panic)       echo 'https://github.com/Di-kairos/panic' ;;
    seedsplit)   echo 'https://github.com/Di-kairos/seedsplit' ;;
    ghostdraft)  echo 'https://github.com/Di-kairos/ghostdraft' ;;
  esac
}

_tool_installed() { command -v "$1" >/dev/null 2>&1; }

# Запустить тул, не убивая цикл при ненулевом коде. Если тула нет — хинт.
_run_tool() {
  local tool="$1"; shift
  if ! _tool_installed "$tool"; then
    echo "${C_YEL}$(t install_hint "$tool" "$(_tool_repo "$tool")")${C_RST}" >&2
    return 0
  fi
  "$tool" "$@" || true
}

# --- статус для dashboard (только чтение; деградирует в unknown, не угадывает) ---
_status_vault() {
  # Открыт = том примонтирован. ASSUMPTION: на macOS hdiutil создаёт mountpoint-каталог
  # /Volumes/SecretVault при attach и удаляет его при detach — поэтому наличие каталога
  # эквивалентно «смонтирован». Stale-каталог (ручной mkdir) дал бы ложный «open», но это
  # вне обычного потока securetrash vault open/close.
  if [[ -d "$VAULT_VOLUME" ]]; then echo open
  elif [[ -e "$VAULT_CONTAINER" ]]; then echo closed
  else echo none; fi
}
_status_filevault() {
  command -v fdesetup >/dev/null 2>&1 || { echo unknown; return; }
  # Вывод захватываем в переменную и матчим here-string, а НЕ через прямой пайп
  # `fdesetup ... | grep -q`: под `set -o pipefail` такой пайп ложно «падает» —
  # grep -q закрывает канал на первом совпадении, источник получает SIGPIPE (код
  # 141), и pipefail делает весь конвейер ненулевым (ложный unknown). См. также
  # _status_vaultwatch — там этот же баг давал «idle» при активной сессии.
  local s; s="$(fdesetup status 2>/dev/null)"
  if   grep -qi "FileVault is On"  <<<"$s"; then echo on
  elif grep -qi "FileVault is Off" <<<"$s"; then echo off
  else echo unknown; fi
}
_status_vaultwatch() {
  _tool_installed vaultwatch || { echo absent; return; }
  # Активная сессия = вывод status содержит "session:"/"сессия:". Захват в переменную +
  # here-string (а не `vaultwatch status | grep -q`): прямой пайп под pipefail ложно
  # давал «idle» — grep -q закрывает канал после первой строки, vaultwatch ловит SIGPIPE
  # (141), pipefail делает конвейер ненулевым. Подробности — в _status_filevault.
  local out; out="$(vaultwatch status 2>/dev/null)"
  if grep -qiE 'session:|сессия:' <<<"$out"; then echo active; else echo idle; fi
}

# Цветная точка по состоянию: ok=green, warn=yellow, dim=grey.
_dot() {
  case "$1" in
    ok)   printf '%s●%s' "$C_GRN" "$C_RST" ;;
    warn) printf '%s●%s' "$C_YEL" "$C_RST" ;;
    *)    printf '%s●%s' "$C_DIM" "$C_RST" ;;
  esac
}

# Один пункт меню: серый + (not installed), если тул отсутствует.
_menu_item() {
  local num="$1" label="$2" tool="${3:-}"
  if [[ -n "$tool" ]] && ! _tool_installed "$tool"; then
    printf '  %s%s) %s (%s)%s\n' "$C_DIM" "$num" "$label" "$(t not_installed)" "$C_RST"
  else
    printf '  %s) %s\n' "$num" "$label"
  fi
}

_render() {
  local v fv vw vline
  v="$(_status_vault)"; fv="$(_status_filevault)"; vw="$(_status_vaultwatch)"
  clear 2>/dev/null || true
  printf '\n  %s%s%s' "$C_BLD" "$(t title)" "$C_RST"
  printf '                          macOS\n\n'

  # Vault
  if [[ "$v" == open ]]; then
    printf '  %s      %s %s  (%s)   %s⚠ %s%s\n' \
      "$(t vault)" "$(_dot warn)" "$(t vault_open)" "$VAULT_VOLUME" "$C_YEL" "$(t vault_risk)" "$C_RST"
  elif [[ "$v" == none ]]; then
    printf '  %s      %s %s\n' "$(t vault)" "$(_dot dim)" "$(t vault_none)"
  else
    printf '  %s      %s %s\n' "$(t vault)" "$(_dot ok)" "$(t vault_closed)"
  fi
  # FileVault
  case "$fv" in
    on)  printf '  %s  %s %s\n' "$(t fv)" "$(_dot ok)"   "$(t on)" ;;
    off) printf '  %s  %s %s\n' "$(t fv)" "$(_dot warn)" "$(t off)" ;;
    *)   printf '  %s  %s %s\n' "$(t fv)" "$(_dot dim)"  "$(t unknown)" ;;
  esac
  # vaultwatch
  case "$vw" in
    active) vline="$(vaultwatch status 2>/dev/null | grep -iE 'TTL|auto-exit|авто-выход' | head -1 | sed 's/^ *//')"
            printf '  %s %s %s%s\n' "$(t vw)" "$(_dot ok)" "$(t vw_active)" "${vline:+ — $vline}" ;;
    idle)   printf '  %s %s %s\n' "$(t vw)" "$(_dot dim)" "$(t vw_idle)" ;;
    *)      : ;;  # absent → строку vaultwatch не показываем
  esac
  echo
  _menu_item 1 "$(t m_status)"
  if _tool_installed panic; then
    printf '  %s2)%s 🔒 %s\n' "$C_BLD" "$C_RST" "$(t m_panic)"
  else
    printf '  %s2) 🔒 %s (%s)%s\n' "$C_DIM" "$(t m_panic)" "$(t not_installed)" "$C_RST"
  fi
  # Группы-подменю (3–5). Top-level держим коротким: чтение (1) и тревога (2) —
  # мгновенно наверху; всё остальное сгруппировано по смыслу. Сами пункты внутри
  # подменю гасятся серым, если их тул отсутствует, поэтому группы тут всегда активны.
  printf '  3) %s\n' "$(t m_t_vault)"
  printf '  4) %s\n' "$(t m_t_notepad)"
  printf '  5) %s\n' "$(t m_t_secrets)"
  printf '  0) %s\n\n' "$(t m_quit)"
}

_pause() { read -r -p "  $(t press_enter)… " _ <&0 || true; }

# Подтверждение: 0 только при 'yes' (регистр не важен: yes/YES/Yes). Целое слово —
# одной буквы 'y' мало для необратимых операций. `case` — bash 3.2-safe (без ${ans,,}).
_confirm() {
  local ans
  read -r -p "  $1 $(t type_yes): " ans <&0 || return 1
  case "$ans" in [Yy][Ee][Ss]) return 0 ;; *) return 1 ;; esac
}

# --- действия ---
_act_status() {
  _run_tool securetrash check
  if _tool_installed vaultwatch; then echo; _run_tool vaultwatch status; fi
  _pause
}
_act_panic() {
  if ! _tool_installed panic; then
    echo "${C_YEL}$(t install_hint panic "$(_tool_repo panic)")${C_RST}" >&2
    _pause; return
  fi
  if ! _confirm "$(t confirm_panic)"; then echo "  $(t cancelled)"; _pause; return; fi
  local hard=""
  if _confirm "$(t ask_hard)"; then hard="--hard"; fi
  # shellcheck disable=SC2086
  _run_tool panic now $hard
  _pause
}
# Спросить потолок размера для нового сейфа. Echo выбранного размера в stdout (пусто = дефолт
# тула 1g), return 1 при неверном формате (caller отменяет create/reset). Подсказки/предупреждения
# идут в stderr, чтобы не попасть в подставляемый аргумент. sparsebundle тонкий → это ЛИМИТ, не резерв.
_ask_vault_size() {
  local free_g size num
  free_g="$(df -g "$HOME" 2>/dev/null | awk 'NR==2{print $4}')"
  [[ -n "$free_g" ]] && echo "  ${C_DIM}$(t size_free "$free_g")${C_RST}" >&2
  echo "  $(t size_prompt)" >&2
  read -r -p "  > " size <&0 || size=""
  [[ -z "$size" ]] && return 0   # пусто → дефолт тула (на stdout ничего)
  if ! [[ "$size" =~ ^[0-9]+[gGmM]?$ ]]; then
    echo "  ${C_YEL}$(t size_bad)${C_RST}" >&2; return 1
  fi
  # Потолок (в ГБ) больше свободного? Предупреждаем, но разрешаем — это лимит, не резерв.
  if [[ -n "$free_g" && "$size" =~ ^([0-9]+)[gG]$ ]]; then
    num="${BASH_REMATCH[1]}"
    (( num > free_g )) && echo "  ${C_YEL}$(t size_cap_warn "$num" "$free_g")${C_RST}" >&2
  fi
  echo "$size"
}
_act_vault() {
  # Трёхсостоянийно: нет контейнера → создать (иначе пользователь упирался в тупик
  # «нет контейнера, сначала vault create» без видимого пути к созданию); закрыт → открыть;
  # открыт → закрыть. На создании спрашиваем размер (cap); пароль securetrash спросит сам.
  case "$(_status_vault)" in
    open)   _run_tool securetrash vault close ;;
    closed) _run_tool securetrash vault open ;;
    none)
      echo "  $(t vault_setup_hint)"
      local sz
      # неверный формат размера → _ask_vault_size вернёт 1 → отменяем создание (не тупик).
      if sz="$(_ask_vault_size)"; then
        # shellcheck disable=SC2086  # пусто → без аргумента = дефолтный размер тула
        _run_tool securetrash vault create $sz
      fi
      ;;
  esac
  _pause
}
# Уничтожение сейфа — необратимо. Лаунчер предупреждает, но реальное подтверждение (yes)
# и отказ при смонтированном томе с открытыми файлами — на стороне securetrash.
_act_destroy() {
  if ! _tool_installed securetrash; then
    echo "${C_YEL}$(t install_hint securetrash "$(_tool_repo securetrash)")${C_RST}" >&2
    _pause; return
  fi
  if [[ "$(_status_vault)" == none ]]; then
    echo "  $(t destroy_none)"; _pause; return
  fi
  echo "  ${C_YEL}$(t destroy_hint)${C_RST}"
  _run_tool securetrash vault destroy
  _pause
}
# Очистить сейф = securetrash vault reset (crypto-shred контейнера + создать пустой заново).
# Честная гарантия безвозвратности: in-place перезапись на SSD — best-effort (тот же ключ
# продолжает расшифровывать остаточные блоки), а reset выкидывает ключ. Реальный yes-confirm
# и запрос пароля нового сейфа — на стороне securetrash; лаунчер лишь предупреждает.
_act_empty() {
  if ! _tool_installed securetrash; then
    echo "${C_YEL}$(t install_hint securetrash "$(_tool_repo securetrash)")${C_RST}" >&2
    _pause; return
  fi
  if [[ "$(_status_vault)" == none ]]; then
    echo "  $(t empty_none)"; _pause; return
  fi
  echo "  ${C_YEL}$(t empty_hint)${C_RST}"
  local sz
  if sz="$(_ask_vault_size)"; then
    # shellcheck disable=SC2086  # пусто → дефолтный размер тула
    _run_tool securetrash vault reset $sz
  fi
  _pause
}
# Подсказка по выходу из редактора (иначе новичок не знает, как сохранить и выйти).
_editor_exit_hint() {
  case "$1" in
    *vim|*vi)  echo ':wq' ;;
    *nano|*pico) echo 'Ctrl-O, Enter, Ctrl-X' ;;
    *emacs)    echo 'Ctrl-X Ctrl-S, Ctrl-X Ctrl-C' ;;
    *)         echo 'save & quit' ;;
  esac
}
_act_split() {
  # seedsplit split молча читает stdin — без подсказки новичок видит пустой курсор.
  echo "  $(t split_prompt)"
  if _run_tool seedsplit split; then echo; echo "  $(t split_done)"; fi
  _pause
}
_act_combine() {
  echo "  $(t combine_prompt)"
  _run_tool seedsplit combine
  _pause
}
# Запуск `ghostdraft new` с подсказкой про редактор. $1 — опц. флаг (напр. --clipboard).
_ghost_new() {
  local flag="$1" ed
  # Зеркалим выбор редактора ghostdraft (иначе подсказка врёт): $EDITOR → vim → nano.
  if [[ -n "${EDITOR:-}" ]]; then ed="$EDITOR"
  elif command -v vim >/dev/null 2>&1; then ed="vim"
  else ed="nano"; fi
  echo "  $(t ghost_editor_hint "$ed" "$(_editor_exit_hint "$ed")")"
  if [[ -n "$flag" ]]; then
    echo "  $(t ghost_clip_hint)"
    _run_tool ghostdraft new "$flag"
  else
    _run_tool ghostdraft new
  fi
}
# Подменю «Блокнот» (ghostdraft): эфемерная заметка / pipe / new+clipboard. Цикл до «назад»,
# чтобы не выходить в дашборд после каждого действия (можно сделать несколько подряд).
_menu_notepad() {
  while true; do
    clear 2>/dev/null || true
    printf '\n  %s%s%s\n\n' "$C_BLD" "$(t h_notepad)" "$C_RST"
    _menu_item 1 "$(t ghost_new)"      ghostdraft
    _menu_item 2 "$(t ghost_pipe)"     ghostdraft
    _menu_item 3 "$(t ghost_new_clip)" ghostdraft
    printf '  0) %s\n\n' "$(t back)"
    local c; read -r -p "  $(t choose): " c <&0 || return 0
    case "$c" in
      1) _ghost_new "" ; _pause ;;
      # pipe читает stdin — без него висел бы на пустом курсоре. Подаём буфер обмена.
      2) echo "  $(t ghost_pipe_hint)"; pbpaste 2>/dev/null | _run_tool ghostdraft pipe; _pause ;;
      # «новый + скопировать»: для рабочего «написал ключ → вставил в приложение» —
      # ghostdraft new --clipboard сам кладёт в буфер и чистит его через ~20с.
      3) _ghost_new --clipboard ; _pause ;;
      0|q|Q) return 0 ;;
      *) : ;;
    esac
  done
}
_act_watch() {
  # Охрана уже активна → п.7 работает как «снять» (toggle). Иначе из меню её было
  # не выключить.
  if [[ "$(_status_vaultwatch)" == active ]]; then
    _run_tool vaultwatch stop "$VAULT_VOLUME"
    _pause; return
  fi
  local ttl; read -r -p "  $(t ask_ttl) " ttl <&0 || ttl=""
  if [[ -n "$ttl" ]]; then
    # Валидируем формат тут: иначе кривой ввод даёт ошибку vaultwatch + «idle» в
    # дашборде, и непонятно, запустилось оно или нет.
    if ! [[ "$ttl" =~ ^[0-9]+[smhd]?$ ]]; then
      echo "  ${C_YEL}$(t ttl_bad)${C_RST}" >&2; _pause; return
    fi
    _run_tool vaultwatch start --ttl "$ttl" "$VAULT_VOLUME"
  else
    _run_tool vaultwatch start "$VAULT_VOLUME"
  fi
  _pause
}

# Подменю «Сейф»: все операции с контейнером в одном месте (по просьбе Mr.Di — иначе плоское
# меню было «лопатой»). vaultwatch сторожит ИМЕННО открытый сейф → она тоже здесь, не отдельным
# блоком. Пункт 1 — динамический по состоянию (нет → создать; закрыт → открыть; открыт → закрыть),
# переиспользует трёхсостоянийный _act_vault. Деструктив (empty/destroy) — серым при отсутствии
# securetrash или сейфа; реальные confirm — внутри securetrash.
_menu_vault() {
  while true; do
    local v vw
    v="$(_status_vault)"; vw="$(_status_vaultwatch)"
    clear 2>/dev/null || true
    printf '\n  %s%s%s\n\n' "$C_BLD" "$(t h_vault)" "$C_RST"
    case "$v" in
      none)   _menu_item 1 "$(t m_v_create)" securetrash ;;
      closed) _menu_item 1 "$(t m_v_open)"   securetrash ;;
      open)   _menu_item 1 "$(t m_v_close)"  securetrash ;;
    esac
    # 2 Empty (reset) — серый при отсутствии securetrash / сейфа
    if ! _tool_installed securetrash; then
      printf '  %s2) %s (%s)%s\n' "$C_DIM" "$(t m_empty)" "$(t not_installed)" "$C_RST"
    elif [[ "$v" == none ]]; then
      printf '  %s2) %s (%s)%s\n' "$C_DIM" "$(t m_empty)" "$(t empty_na)" "$C_RST"
    else
      printf '  2) %s\n' "$(t m_empty)"
    fi
    # 3 Destroy — серый при отсутствии securetrash / сейфа
    if ! _tool_installed securetrash; then
      printf '  %s3) 💣 %s (%s)%s\n' "$C_DIM" "$(t m_destroy)" "$(t not_installed)" "$C_RST"
    elif [[ "$v" == none ]]; then
      printf '  %s3) 💣 %s (%s)%s\n' "$C_DIM" "$(t m_destroy)" "$(t destroy_na)" "$C_RST"
    else
      printf '  3) 💣 %s\n' "$(t m_destroy)"
    fi
    # 4 Watch — toggle (active → снять, иначе → сторожить)
    if [[ "$vw" == active ]]; then
      _menu_item 4 "$(t m_unwatch)" vaultwatch
    else
      _menu_item 4 "$(t m_watch)"   vaultwatch
    fi
    printf '  0) %s\n\n' "$(t back)"
    local c; read -r -p "  $(t choose): " c <&0 || return 0
    case "$c" in
      1) _act_vault ;;
      2) _act_empty ;;
      3) _act_destroy ;;
      4) _act_watch ;;
      0|q|Q) return 0 ;;
      *) : ;;
    esac
  done
}
# Подменю «Секреты» (seedsplit): разбить / собрать. Цикл до «назад».
_menu_secrets() {
  while true; do
    clear 2>/dev/null || true
    printf '\n  %s%s%s\n\n' "$C_BLD" "$(t h_secrets)" "$C_RST"
    _menu_item 1 "$(t m_split)"   seedsplit
    _menu_item 2 "$(t m_combine)" seedsplit
    printf '  0) %s\n\n' "$(t back)"
    local c; read -r -p "  $(t choose): " c <&0 || return 0
    case "$c" in
      1) _act_split ;;
      2) _act_combine ;;
      0|q|Q) return 0 ;;
      *) : ;;
    esac
  done
}

usage() {
  cat <<EOF
paranoid $PARANOID_VERSION — interactive launcher for the Paranoid Tools ecosystem.

Usage: paranoid            launch the interactive dashboard
       paranoid version    print the version
       paranoid help       show this help

A thin launcher over the five CLIs (securetrash, vaultwatch, panic, seedsplit,
ghostdraft). It holds no secrets and adds no crypto — it runs the same signed
tools and shows their output (limits and verdicts included) unaltered.
EOF
}

main() {
  case "${1:-}" in
    version|-v|--version) echo "paranoid $PARANOID_VERSION"; return 0 ;;
    help|-h|--help)       usage; return 0 ;;
    "") : ;;
    *) echo "Unknown command: $1" >&2; usage >&2; return 1 ;;
  esac

  # Ctrl-C в подпункте → назад в меню (не выход). На dashboard — чистый выход.
  trap 'echo' INT
  local choice
  while true; do
    _render
    read -r -p "  $(t choose): " choice <&0 || { echo; return 0; }
    case "$choice" in
      1) _act_status ;;
      2) _act_panic ;;
      3) _menu_vault ;;
      4) _menu_notepad ;;
      5) _menu_secrets ;;
      0|q|Q) echo; return 0 ;;
      *) : ;;   # неверный ввод → перерисовать меню
    esac
  done
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
