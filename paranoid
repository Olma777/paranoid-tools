#!/usr/bin/env bash
# paranoid — интерактивный лаунчер экосистемы Paranoid Tools (Фаза A).
#
# ЧЕСТНО: это ТОНКИЙ лаунчер, не новый инструмент. Он не содержит крипты и НЕ трогает
# секреты — секреты вводятся напрямую в stdin нужного CLI. paranoid лишь показывает живой
# статус и запускает те же пять подписанных CLI, ничего не пряча (Scope & limitations и
# вердикты `check` идут на экран как есть). Глобального хоткея/демона тут нет — это Фаза B.
#
# Зависимостей — ноль (чистый Bash). Установленные тулы ищутся в PATH по имени; отсутствующий
# тул показывается серым с хинтом на установку, а не подделывается.
set -uo pipefail

PARANOID_VERSION="0.1.0"

# Точка монтирования vault (та же, что у securetrash). Переопределяема (тесты/иной том).
VAULT_VOLUME="${ST_VAULT_VOLUME:-/Volumes/SecretVault}"
# Файл-контейнер vault (securetrash default). Нужен, чтобы отличить «закрыт» от «ещё не создан»
# — иначе пункт меню Vault на чистой системе вёл бы к тупику «нет контейнера».
VAULT_CONTAINER="${ST_VAULT_PATH:-$HOME/SecureVault.sparsebundle}"

# --- locale: en по умолчанию; ru — если ST_LANG или системная локаль начинаются с 'ru' ---
_detect_locale() {
  local want="${ST_LANG:-}"
  if [[ -n "$want" ]]; then
    case "$want" in ru*) echo ru ;; *) echo en ;; esac
    return
  fi
  case "${LC_ALL:-${LANG:-}}" in ru*) echo ru ;; *) echo en ;; esac
}
LOCALE="${ST_LOCALE:-$(_detect_locale)}"

# --- цвет только в TTY ---
if [[ -t 1 ]]; then
  C_GRN=$'\033[32m'; C_YEL=$'\033[33m'; C_DIM=$'\033[2m'; C_BLD=$'\033[1m'; C_RST=$'\033[0m'
else
  C_GRN=""; C_YEL=""; C_DIM=""; C_BLD=""; C_RST=""
fi

# --- i18n (только chrome лаунчера; вывод самих тулов локализуют они сами) ---
t() {
  case "$LOCALE:$1" in
    en:title)        echo 'PARANOID TOOLS' ;;
    ru:title)        echo 'PARANOID TOOLS' ;;
    en:vault)        echo 'Vault:' ;;        ru:vault)        echo 'Сейф:' ;;
    en:vault_open)   echo 'OPEN' ;;          ru:vault_open)   echo 'ОТКРЫТ' ;;
    en:vault_closed) echo 'closed' ;;        ru:vault_closed) echo 'закрыт' ;;
    en:vault_none)   echo 'not set up' ;;    ru:vault_none)   echo 'не создан' ;;
    en:vault_setup_hint) echo 'No vault yet — creating one (securetrash will ask for size & password).' ;;
    ru:vault_setup_hint) echo 'Сейфа ещё нет — создаём (securetrash спросит размер и пароль).' ;;
    en:vault_risk)   echo 'at risk while open' ;; ru:vault_risk) echo 'под угрозой, пока открыт' ;;
    en:fv)           echo 'FileVault:' ;;    ru:fv)           echo 'FileVault:' ;;
    en:on)           echo 'ON' ;;            ru:on)           echo 'ВКЛ' ;;
    en:off)          echo 'OFF' ;;           ru:off)          echo 'ВЫКЛ' ;;
    en:unknown)      echo 'unknown' ;;       ru:unknown)      echo 'неизвестно' ;;
    en:vw)           echo 'vaultwatch:' ;;   ru:vw)           echo 'vaultwatch:' ;;
    en:vw_active)    echo 'active' ;;        ru:vw_active)    echo 'активен' ;;
    en:vw_idle)      echo 'idle' ;;          ru:vw_idle)      echo 'нет сессий' ;;
    en:m_status)     echo 'Status — full read-only check' ;;
    ru:m_status)     echo 'Статус — полная проверка (только чтение)' ;;
    en:m_panic)      echo 'PANIC NOW — hide & lock (confirm)' ;;
    ru:m_panic)      echo 'ПАНИКА — спрятать и запереть (подтвердить)' ;;
    en:m_vault)      echo 'Vault — create / open / close' ;;
    ru:m_vault)      echo 'Сейф — создать / открыть / закрыть' ;;
    en:m_destroy)    echo 'Destroy the vault (irreversible)' ;;
    ru:m_destroy)    echo 'Уничтожить сейф (необратимо)' ;;
    en:destroy_na)   echo 'no vault' ;;       ru:destroy_na)   echo 'нет сейфа' ;;
    en:destroy_hint) echo 'This permanently destroys the vault and everything inside it. securetrash will ask you to confirm with "yes".' ;;
    ru:destroy_hint) echo 'Это безвозвратно уничтожит сейф и всё, что внутри. securetrash попросит подтвердить словом «yes».' ;;
    en:destroy_none) echo 'No vault to destroy — create one first (menu item 3).' ;;
    ru:destroy_none) echo 'Уничтожать нечего — сначала создай сейф (пункт 3).' ;;
    en:m_split)      echo 'Split a secret (seedsplit)' ;;
    ru:m_split)      echo 'Разбить секрет (seedsplit)' ;;
    en:m_combine)    echo 'Combine shares (seedsplit)' ;;
    ru:m_combine)    echo 'Собрать из долей (seedsplit)' ;;
    en:m_ghost)      echo 'Ghostdraft — ephemeral note / pipe' ;;
    ru:m_ghost)      echo 'Ghostdraft — эфемерная заметка / pipe' ;;
    en:m_watch)      echo 'Watch vault — guard + TTL (vaultwatch)' ;;
    ru:m_watch)      echo 'Сторожить сейф — guard + TTL (vaultwatch)' ;;
    en:m_unwatch)    echo 'Stop watching the vault (vaultwatch)' ;;
    ru:m_unwatch)    echo 'Снять охрану сейфа (vaultwatch)' ;;
    en:m_quit)       echo 'Quit' ;;          ru:m_quit)       echo 'Выход' ;;
    en:not_installed) echo 'not installed' ;; ru:not_installed) echo 'не установлен' ;;
    en:install_hint)  printf 'Install %s: %s' "$2" "$3" ;;
    ru:install_hint)  printf 'Установить %s: %s' "$2" "$3" ;;
    en:choose)       echo 'Choose' ;;        ru:choose)       echo 'Выбор' ;;
    en:press_enter)  echo 'Press Enter to continue' ;;
    ru:press_enter)  echo 'Нажми Enter, чтобы продолжить' ;;
    en:confirm_panic) echo 'Run panic now? This hides & locks everything.' ;;
    ru:confirm_panic) echo 'Запустить панику? Это спрячет и запрёт всё.' ;;
    en:ask_hard)     echo 'Also kill cloud daemons & clear recent items (--hard)?' ;;
    ru:ask_hard)     echo 'Также прибить cloud-демоны и очистить recent (--hard)?' ;;
    en:ask_ttl)      echo 'Auto-exit after (e.g. 30m, 2h; empty = no timer):' ;;
    ru:ask_ttl)      echo 'Авто-выход через (напр. 30m, 2h; пусто = без таймера):' ;;
    en:cancelled)    echo 'Cancelled.' ;;    ru:cancelled)    echo 'Отменено.' ;;
    en:ghost_new)    echo 'new — edit an ephemeral draft' ;;
